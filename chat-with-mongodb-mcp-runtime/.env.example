MONGODB_URI=
MONGODB_DB_NAME=network_monitoring

GROVE_API_KEY=
GROVE_MODEL=gpt-5.5
GROVE_API_URL=https://grove-gateway-prod.azure-api.net/grove-foundry-prod/openai/v1/responses

VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-4
VOYAGE_EMBEDDING_DIMENSIONS=1024
# Atlas model keys (al-...) use https://ai.mongodb.com/v1/embeddings
# Voyage platform keys (pa-...) use https://api.voyageai.com/v1/embeddings

MCP_SERVER_COMMAND=npx
MCP_SERVER_ARGS=-y mongodb-mcp-server@latest

PORT=4003
CLIENT_PORT=5178
CLIENT_ORIGIN=http://127.0.0.1:5178
DEMO_RUNTIME_URL=http://127.0.0.1:4000/api
DEMO_ID=chat-with-mongodb-mcp

# Agent loop safeguards (industry defaults: ~15 steps, generate-then-synthesize fallback)
CHAT_MAX_TOOL_ITERATIONS=15
CHAT_FORCE_ANSWER_WHEN_REMAINING=2
CHAT_DUPLICATE_STOP_THRESHOLD=3
CHAT_MAX_TOOL_RESULT_CHARS=6000

VITE_API_URL=http://127.0.0.1:4003/api

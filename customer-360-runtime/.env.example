MONGODB_URI=
MONGODB_DB_NAME=customer_360

GROVE_API_KEY=
GROVE_MODEL=gpt-5.5
GROVE_API_URL=https://grove-gateway-prod.azure-api.net/grove-foundry-prod/openai/v1/responses

VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-4
VOYAGE_EMBEDDING_DIMENSIONS=1024

MCP_SERVER_COMMAND=node
MCP_SERVER_ARGS=node_modules/mongodb-mcp-server/dist/esm/index.js

PORT=4004
CLIENT_PORT=5179
CLIENT_ORIGIN=http://127.0.0.1:5179
DEMO_RUNTIME_URL=http://127.0.0.1:4000/api
DEMO_ID=customer-360

CUSTOMER_SEED_COUNT=1000000
INTERACTION_SEED_COUNT=250000
# Set to 1 once to rebuild customers_search_index with autocomplete mappings
# CUSTOMERS_SEARCH_FORCE_REBUILD=1

CHAT_MAX_TOOL_ITERATIONS=15
CHAT_FORCE_ANSWER_WHEN_REMAINING=2
CHAT_DUPLICATE_STOP_THRESHOLD=3
CHAT_MAX_TOOL_RESULT_CHARS=6000

VITE_API_URL=http://127.0.0.1:4004/api

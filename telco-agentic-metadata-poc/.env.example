MONGODB_URI=
MONGODB_DB_NAME=agentic_metadata_demo

GROVE_API_KEY=
GROVE_MODEL=gpt-5.5
GROVE_API_URL=https://grove-gateway-prod.azure-api.net/grove-foundry-prod/openai/v1/responses
# GROVE_BASE_URL is accepted as an alias for GROVE_API_URL in this repo.
GROVE_TIMEOUT_MS=45000

VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-4
VOYAGE_EMBEDDING_DIMENSIONS=1024

REQUIRE_VECTOR_SEARCH=false
REQUIRE_EMBEDDINGS=false
REQUIRE_LLM=false
ENFORCE_POLICY=false
QUERY_LIMIT_DEFAULT=100
